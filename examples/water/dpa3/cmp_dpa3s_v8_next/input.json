{
  "_comment": "dpa3s V8 (DPA3-Next): 4-subblock pre-norm invariant transformer",
  "model": {
    "type_map": ["O", "H"],
    "descriptor": {
      "type": "dpa3s_v8_next",
      "n_dim": 128,
      "e_dim": 128,
      "a_dim": 64,
      "nlayers": 6,
      "e_rcut": 6.0,
      "e_rcut_smth": 5.0,
      "e_sel": 120,
      "a_rcut": 4.0,
      "a_rcut_smth": 3.5,
      "a_sel": 40,
      "num_radial": 12,
      "num_angular": 8,
      "sel_reduce_factor": 10.0,
      "activation_function": "silu",
      "precision": "float32",
      "seed": 42
    },
    "fitting_net": {
      "neuron": [240, 240, 240],
      "resnet_dt": true,
      "precision": "float32",
      "activation_function": "silu",
      "seed": 42
    }
  },
  "learning_rate": {
    "type": "cosine",
    "start_lr": 0.0005,
    "stop_lr": 0.000001,
    "warmup_steps": 5000,
    "warmup_start_factor": 0.2
  },
  "loss": {
    "type": "ener",
    "start_pref_e": 0.2,
    "limit_pref_e": 20,
    "start_pref_f": 100,
    "limit_pref_f": 20,
    "start_pref_v": 0.02,
    "limit_pref_v": 1
  },
  "optimizer": {
    "type": "AdamW",
    "adam_beta1": 0.9,
    "adam_beta2": 0.999,
    "weight_decay": 0.001
  },
  "training": {
    "stat_file": "./stat.hdf5",
    "training_data": {
      "systems": ["../data/data_0", "../data/data_1", "../data/data_2"],
      "batch_size": 1
    },
    "validation_data": {
      "systems": ["../data/data_3"],
      "batch_size": 1
    },
    "numb_steps": 20,
    "gradient_max_norm": 5.0,
    "seed": 10,
    "disp_file": "lcurve.out",
    "disp_freq": 5,
    "save_freq": 20
  }
}
