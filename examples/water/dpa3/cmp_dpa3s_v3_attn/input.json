{
  "_comment": "dpa3s V3 variant: edge-gated attention + SwiGLU FFN + RBF + RMSNorm",
  "model": {
    "type_map": ["O", "H"],
    "descriptor": {
      "type": "dpa3s_v3_attn",
      "n_dim": 128,
      "e_dim": 64,
      "a_dim": 32,
      "nlayers": 6,
      "e_rcut": 6.0,
      "e_rcut_smth": 5.3,
      "e_sel": 120,
      "a_rcut": 4.0,
      "a_rcut_smth": 3.5,
      "a_sel": 40,
      "axis_neuron": 4,
      "sel_reduce_factor": 10.0,
      "num_edge_basis": 20,
      "num_angle_basis": 16,
      "ffn_hidden_mult": 4.0,
      "activation_function": "silu",
      "use_tebd_bias": false,
      "precision": "float32",
      "concat_output_tebd": false,
      "seed": 1,
      "tebd_mode": "embedding",
      "mlp_init": "glorot",
      "bias_init_zero": true,
      "gate_bias_zero": true,
      "norm_position": "pre"
    },
    "fitting_net": {
      "neuron": [240, 240, 240],
      "resnet_dt": true,
      "precision": "float32",
      "activation_function": "silu",
      "seed": 1
    }
  },
  "learning_rate": {
    "type": "exp",
    "decay_steps": 5000,
    "start_lr": 0.001,
    "stop_lr": 3e-5
  },
  "loss": {
    "type": "ener",
    "start_pref_e": 0.2,
    "limit_pref_e": 20,
    "start_pref_f": 100,
    "limit_pref_f": 60,
    "start_pref_v": 0.0,
    "limit_pref_v": 0.0
  },
  "optimizer": {
    "type": "AdamW",
    "adam_beta1": 0.9,
    "adam_beta2": 0.999,
    "weight_decay": 0.001
  },
  "training": {
    "stat_file": "./stat.hdf5",
    "training_data": {
      "systems": [
        "/aisi/zhangd/claude_eva/claude_space/deepmd-kit-clean/examples/water/data/data_0",
        "/aisi/zhangd/claude_eva/claude_space/deepmd-kit-clean/examples/water/data/data_1",
        "/aisi/zhangd/claude_eva/claude_space/deepmd-kit-clean/examples/water/data/data_2"
      ],
      "batch_size": 1
    },
    "validation_data": {
      "systems": [
        "/aisi/zhangd/claude_eva/claude_space/deepmd-kit-clean/examples/water/data/data_3"
      ],
      "batch_size": 1
    },
    "numb_steps": 20,
    "gradient_max_norm": 5.0,
    "seed": 10,
    "disp_file": "lcurve.out",
    "disp_freq": 5,
    "save_freq": 20
  }
}
